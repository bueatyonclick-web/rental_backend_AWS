# Copy these into Vercel: Project Settings -> Environment Variables
# Root Directory in Vercel must be: rental_backend/core

# --- Required for production ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Your deployed URL (Vercel or AWS EC2)
TEMPLATES_BASE_URL=https://your-project-name.vercel.app
DJANGO_ALLOWED_HOSTS=your-project-name.vercel.app,13.205.169.178

# --- CORS (comma-separated, include your app / frontend URLs) ---
CORS_ALLOWED_ORIGINS=https://your-project-name.vercel.app,http://127.0.0.1:8000,http://13.205.169.178,http://13.205.169.178:8000

# --- CSRF (required for Django admin / form POSTs from browser) ---
CSRF_TRUSTED_ORIGINS=http://13.205.169.178,http://13.205.169.178:8000

# --- Email (Brevo / SMTP) ---
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-password

# --- WhatsApp OTP (HyperSender) ---
HYPERsender_API_KEY=your-hypersender-api-key
HYPERsender_INSTANCE_ID=your-hypersender-instance-id

# --- SMS / 2FA ---
FAST2SMS_API_KEY=your-fast2sms-api-key
TWO_FACTOR_API_KEY=your-two-factor-api-key

# --- Referral links ---
REFERRAL_SIGNUP_BASE_URL=https://play.google.com/store/apps/details?id=com.chaitanya.rentalcothes

# --- Firebase push notifications (paste full JSON on one line) ---
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# --- Alternative database config (use DATABASE_URL OR these, not both) ---
# DB_HOST=your-postgres-host
# DB_NAME=postgres
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_PORT=5432
